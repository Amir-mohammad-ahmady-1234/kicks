
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "mysql"
  url      = env("DATABASE_URL")
}
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  password  String
  role      String @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Products {
  id          String    @id @default(cuid())
  name        String
  description String
  specs       String
  price       Int
  discount    Int?
  mainImage   String
  images      Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime?
  star        Float?
  gender Gender @default(men)
  colors        Json

  suggestedTo   Sugest[] @relation("suggestTo")
  suggestedBy   Sugest[] @relation("suggestFrom")

  size          Json

  category categoryP @default(crocs)

  @@map("products")
}

model Sugest {
  productId   String
  suggestedId String

  product     Products @relation("suggestFrom", fields: [productId], references: [id])

  suggested   Products @relation("suggestTo", fields: [suggestedId], references: [id])

  @@unique([productId, suggestedId])
  @@map("suggests")
}




enum Role {
  user
  admin
}
enum Gender {
  men
  women
}
enum categoryP {
crocs
nirkenstock
clarks
timberland
allen
oofos
sorel
hunter
}
